{
  "github_api_version": "2026-03-10",
  "trending": {
    "period": "weekly",
    "spoken_language": "any",
    "programming_language": "any",
    "preserve_github_order": true,
    "max_candidates": 25,
    "metadata_workers": 5
  },
  "supplemental_search": true,
  "minimum_stars": 20,
  "minimum_weekly_star_gain": 10,
  "new_project_days": 14,
  "results_per_query": 30,
  "search_delay_seconds": 2.1,
  "report_size": {
    "official": 10,
    "rising": 5,
    "new": 3
  },
  "deepseek": {
    "enabled": true,
    "model": "deepseek-v4-pro",
    "base_url": "https://api.deepseek.com",
    "max_projects_per_run": 18,
    "max_readme_chars": 6000
  },
  "categories": [
    {

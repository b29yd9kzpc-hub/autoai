      "keywords": [
        "ai agent",
        "ai-agent",
        "ai agents",
        "agentic",
        "autonomous agent",
        "multi-agent"
      ],
      "queries": [
        "topic:ai-agent",
        "topic:autonomous-agents",
        "\"ai agent\" in:name,description"
      ]
    },
    {
